generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------
// Core Tenant / Company
// ----------------------------------
model Tenant {
  id             String    @id @default(uuid())
  organization   String
  owner          String?
  totalUsers     String?
  branchesCount  String?
  status         String    @default("Active")
  createdDate    String?
  plan           String?
  databaseSize   String?
  domain         String?
  provider       String?
  sslStatus      String?
  
  users          User[]
  branches       Branch[]
  departments    Department[]
  teams          Team[]
  projects       Project[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ----------------------------------
// Organization Structure
// ----------------------------------
model Branch {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchName  String
  organization String?
  manager     String?
  employees   String?
  city        String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departmentName   String
  organization     String?
  headOfDepartment String?
  employees        String?
  budget           String?
  status           String   @default("Active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  teams            Team[]
}

model Team {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id])
  teamName    String
  lead        String?
  members     String?
  velocity    String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------------
// Users, Roles & Permissions
// ----------------------------------
model User {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  email       String
  passwordHash String?
  role        String?
  organization String?
  status      String   @default("Active")
  lastLogin   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles   UserRole[]
}

model Role {
  id                 String           @id @default(uuid())
  tenantId           String?
  projectId          String?
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleName           String
  name               String?
  description        String?
  type               String?
  totalUsers         String?
  permissionsGranted String?
  createdBy          String?
  status             String           @default("Active")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  rolePermissions    RolePermission[]
  userRoles          UserRole[]

  @@index([projectId])
}

model Permission {
  id              String           @id @default(uuid())
  name            String?
  module          String?
  canView         String?
  canCreate       String?
  canUpdate       String?
  canDelete       String?
  canImport       String?
  canExport       String?
  canApprove      String?
  action          String?
  resource        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  rolePermissions RolePermission[]

  @@unique([resource, action], name: "resource_action")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  projectId String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId, projectId])
  @@index([userId])
  @@index([roleId])
  @@index([projectId])
}

// ----------------------------------
// AI Platform
// ----------------------------------
model AILog {
  id            String   @id @default(uuid())
  tenantId      String?
  time          String
  provider      String?
  promptSnippet String?  @db.Text
  tokensUsed    String?
  createdAt     DateTime @default(now())
}

model AITemplate {
  id            String   @id @default(uuid())
  tenantId      String?
  templateName  String
  model         String?
  promptSnippet String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model KnowledgeBase {
  id            String   @id @default(uuid())
  tenantId      String?
  documentName  String
  type          String?
  tokens        String?
  chunks        String?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AIProvider {
  id          String   @id @default(uuid())
  tenantId    String?
  provider    String
  model       String?
  status      String   @default("Active")
  requests    String?
  tokens      String?
  avgLatency  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------------
// System & APIs
// ----------------------------------
model APIKey {
  id          String   @id @default(uuid())
  tenantId    String?
  keyName     String
  prefix      String?
  environment String?
  permissions String?
  lastUsed    String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Webhook {
  id          String   @id @default(uuid())
  tenantId    String?
  endpointUrl String
  events      String?
  environment String?
  successRate String?
  lastPing    String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Automation {
  id          String   @id @default(uuid())
  tenantId    String?
  ruleName    String
  eventTrigger String?
  action      String?
  target      String?
  executions  String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Workflow {
  id            String   @id @default(uuid())
  tenantId      String?
  workflowName  String
  trigger       String?
  activeRuns    String?
  successRate   String?
  lastExecution String?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ----------------------------------
// Identity & Devices
// ----------------------------------
model Authentication {
  id              String   @id @default(uuid())
  tenantId        String?
  provider        String
  clientId        String?
  status          String   @default("Active")
  usersConfigured String?
  lastSynced      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Device {
  id          String   @id @default(uuid())
  tenantId    String?
  deviceName  String
  owner       String?
  browser     String?
  operatingSystem String?
  ip          String?
  location    String?
  lastLogin   String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id          String   @id @default(uuid())
  tenantId    String?
  user        String?
  browser     String?
  os          String?
  device      String?
  ipAddress   String?
  location    String?
  lastActivity String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoginLog {
  id          String   @id @default(uuid())
  tenantId    String?
  user        String?
  ipAddress   String?
  country     String?
  browser     String?
  status      String?
  date        String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?
  eventId     String?
  action      String?
  actor       String?
  resource    String?
  ipAddress   String?
  timestamp   String?
  createdAt   DateTime @default(now())
}

// ----------------------------------
// Notifications & Templates
// ----------------------------------
model Channel {
  id            String   @id @default(uuid())
  tenantId      String?
  channelName   String
  provider      String?
  apiKeyStatus  String?
  deliveryRate  String?
  lastUsed      String?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmailTemplate {
  id          String   @id @default(uuid())
  tenantId    String?
  templateName String
  subjectLine String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SMSTemplate {
  id          String   @id @default(uuid())
  tenantId    String?
  templateName String
  messageBody  String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsappTemplate {
  id          String   @id @default(uuid())
  tenantId    String?
  templateName String
  messageBody  String? @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationLog {
  id          String   @id @default(uuid())
  tenantId    String?
  recipient   String?
  channel     String?
  subject     String?
  provider    String?
  status      String?
  sentAt      String?
  createdAt   DateTime @default(now())
}

// ----------------------------------
// Storage & Media
// ----------------------------------
model File {
  id          String   @id @default(uuid())
  tenantId    String?
  fileName    String
  type        String?
  size        String?
  uploadedBy  String?
  date        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------------
// Billing & Subscriptions
// ----------------------------------
model Plan {
  id            String   @id @default(uuid())
  planName      String
  priceMonthly  String?
  priceAnnual   String?
  subscribers   String?
  featuresLimit String?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(uuid())
  tenantId    String?
  invoiceNo   String?
  tenantName  String?
  amount      String?
  dateIssued  String?
  dueDate     String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Coupon {
  id          String   @id @default(uuid())
  code        String
  discount    String?
  duration    String?
  redemptions String?
  maxUses     String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feature {
  id          String   @id @default(uuid())
  featureName String
  key         String?
  availableIn String?
  usageLimit  String?
  createdBy   String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------------
// Tenant Configuration
// ----------------------------------
model Branding {
  id          String   @id @default(uuid())
  tenantId    String?
  tenantName  String?
  primaryColor String?
  logoUrl     String?
  font        String?
  customCss   String?  @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduledReport {
  id          String   @id @default(uuid())
  tenantId    String?
  reportName  String
  type        String?
  schedule    String?
  recipients  String?
  lastRun     String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id                  String          @id @default(uuid())
  tenantId            String
  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  refId               String          @unique
  dbHost              String
  dbPort              Int             @default(3306)
  dbName              String
  dbUsername          String
  dbPasswordEncrypted String          @db.Text
  jwtSecretEncrypted  String          @db.Text
  status              String          @default("provisioning")
  jwtExpiresIn        Int             @default(3600)
  jwtRefreshExpiresIn Int             @default(604800)
  jwtIssuer           String          @default("kiaan-auth")
  jwtAudience         String          @default("kiaan-users")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  apiKeys             ProjectApiKey[]
  authProviders       ProjectAuthProvider[]
  emailTemplates      ProjectEmailTemplate[]
  storageBuckets      StorageBucket[]
  roles               Role[]
  userRoles           UserRole[]

  @@index([tenantId])
}

model ProjectApiKey {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  keyType    String
  keyToken   String   @unique @db.VarChar(700)
  createdAt  DateTime @default(now())

  @@index([projectId])
}

model ProjectAuthProvider {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider     String
  clientId     String?  @db.Text
  clientSecret String?  @db.Text
  isEnabled    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, provider])
  @@index([projectId])
}

model ProjectEmailTemplate {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateType String
  subject     String?
  body        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, templateType])
  @@index([projectId])
}

model StorageBucket {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files     StorageFile[]

  @@unique([projectId, name])
  @@index([projectId])
}

model StorageFile {
  id               String        @id @default(uuid())
  projectId        String
  bucketId         String
  bucket           StorageBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  originalName     String
  storedName       String
  path             String
  mimeType         String
  extension        String
  size             Int
  uploadedBy       String?
  visibility       String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([bucketId, path])
  @@index([projectId])
  @@index([bucketId])
}

